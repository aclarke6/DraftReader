@model ChapterReadViewModel
@{
    ViewData["Title"] = Model.Chapter.Title;
}

<div class="reader-page">

    <button type="button"
            class="reader__contents-toggle"
            id="readerContentsToggle"
            aria-expanded="false"
            aria-controls="readerContentsPanel">
        Contents
    </button>

    <div id="readerContentsPanel" class="reader__contents">
        @if (Model.BookContents is not null)
        {
            <div class="reader__contents-header">
                <a asp-action="Index" class="reader__contents-link reader__contents-link--chapter">@Model.ProjectName</a>
                <a asp-action="Browse"
                   asp-route-id="@Model.BookContents.TopLevelSection.Id"
                   class="reader__contents-link reader__contents-link--chapter">&rsaquo; @Model.BookContents.TopLevelSection.Title</a>
            </div>
            <hr class="reader__contents-divider" />
        }

        <div class="reader__contents-section">
            <div class="reader__contents-label">This chapter</div>
            @foreach (var item in Model.Scenes)
            {
                <a href="#scene-@item.Scene.Id" class="reader__contents-link">@item.Scene.Title</a>
            }
            <a href="#chapter-comments"
                   class="reader__contents-link reader__contents-link--muted">
                &#9998; Chapter Comments
            </a>
        </div>

        @if (Model.BookContents is not null && Model.BookContents.Groups.Any())
        {
            <hr class="reader__contents-divider" />
            <div class="reader__contents-section">
                <div class="reader__contents-label">Other chapters</div>

                @foreach (var group in Model.BookContents.Groups)
                {
                    @if (!string.IsNullOrEmpty(group.Heading))
                    {
                        <div class="reader__contents-subheading">@group.Heading</div>
                    }

                    @foreach (var sub in group.SubGroups)
                    {
                        @if (!string.IsNullOrEmpty(sub.Heading))
                        {
                            <div class="reader__contents-subheading reader__contents-subheading--nested">@sub.Heading</div>
                        }

                        @if (sub.ChapterSection is not null)
                        {
                            <a asp-action="Read"
                                   asp-route-id="@sub.ChapterSection.Id"
                                   class="reader__contents-link @(sub.ChapterSection.Id == Model.Chapter.Id ? "reader__contents-link--active" : "") reader__contents-link--indented">
                                @sub.ChapterSection.Title
                            </a>
                        }
                    }

                    @if (group.ChapterSection is not null)
                    {
                        <a asp-action="Read"
                               asp-route-id="@group.ChapterSection.Id"
                               class="reader__contents-link @(group.ChapterSection.Id == Model.Chapter.Id ? "reader__contents-link--active" : "")">
                            @group.ChapterSection.Title
                        </a>
                    }
                }
            </div>
        }
    </div>

    <div class="chapter-layout">
        <aside class="chapter-sidebar">
            @if (Model.BookContents is not null)
            {
                <div class="chapter-sidebar__header">
                    <a asp-action="Index" class="chapter-sidebar__link chapter-sidebar__link--chapter">@Model.ProjectName</a>
                    <a asp-action="Browse"
                       asp-route-id="@Model.BookContents.TopLevelSection.Id"
                       class="chapter-sidebar__link chapter-sidebar__link--chapter">&rsaquo; @Model.BookContents.TopLevelSection.Title</a>
                </div>
                <hr class="chapter-sidebar__divider" />
            }

            <div class="chapter-sidebar__label">This chapter</div>
            @foreach (var item in Model.Scenes)
            {
                <a href="#scene-@item.Scene.Id" class="chapter-sidebar__link">@item.Scene.Title</a>
            }

            <a href="#chapter-comments"
                   class="chapter-sidebar__link chapter-sidebar__link--muted chapter-sidebar__link--comments">
                &#9998; Chapter Comments
            </a>

            @if (Model.BookContents is not null && Model.BookContents.Groups.Any())
            {
                <hr class="chapter-sidebar__divider" />
                <div class="chapter-sidebar__label">Other chapters</div>

                @foreach (var group in Model.BookContents.Groups)
                {
                    @if (!string.IsNullOrEmpty(group.Heading))
                    {
                        <div class="chapter-sidebar__subheading">@group.Heading</div>
                    }

                    @foreach (var sub in group.SubGroups)
                    {
                        @if (!string.IsNullOrEmpty(sub.Heading))
                        {
                            <div class="chapter-sidebar__subheading chapter-sidebar__subheading--nested">@sub.Heading</div>
                        }

                        @if (sub.ChapterSection is not null)
                        {
                            <a asp-action="Read"
                                   asp-route-id="@sub.ChapterSection.Id"
                                   class="chapter-sidebar__link chapter-sidebar__link--indented @(sub.ChapterSection.Id == Model.Chapter.Id ? "chapter-sidebar__link--active" : "")">
                                @sub.ChapterSection.Title
                            </a>
                        }
                    }

                    @if (group.ChapterSection is not null)
                    {
                        <a asp-action="Read"
                               asp-route-id="@group.ChapterSection.Id"
                               class="chapter-sidebar__link @(group.ChapterSection.Id == Model.Chapter.Id ? "chapter-sidebar__link--active" : "")">
                            @group.ChapterSection.Title
                        </a>
                    }
                }
            }
        </aside>

        <main class="chapter-main">
            @if (Model.Breadcrumb.Any())
            {
                <div class="chapter-breadcrumb">
                    @for (int i = 0; i < Model.Breadcrumb.Count; i++)
                    {
                        @Model.Breadcrumb[i]
                        if (i < Model.Breadcrumb.Count - 1)
                        {
                            <span class="chapter-breadcrumb__sep">&rsaquo;</span>
                        }
                    }
                </div>
            }

            <h2 class="chapter-title">@Model.Chapter.Title</h2>

            @foreach (var item in Model.Scenes)
            {
                var roots = item.Comments.Where(c => c.ParentCommentId == null).ToList();
                var replies = item.Comments.Where(c => c.ParentCommentId != null)
                    .GroupBy(c => c.ParentCommentId!.Value)
                    .ToDictionary(g => g.Key, g => g.ToList());

                <div class="scene-block" id="scene-@item.Scene.Id">
                    <div class="scene-prose">
                        <h4 class="scene-heading">@item.Scene.Title</h4>

                        <div class="scene-prose-shell">
                            <div class="scene-prose-content prose">
                                @Html.Raw(item.Scene.HtmlContent ?? "<p><em>No content.</em></p>")
                            </div>
                        </div>
                    </div>

                    <div class="scene-comments">
                        <div class="scene-comments-label">Comments</div>

                        @foreach (var c in roots)
                        {
                            var commentName = Model.CommentAuthorNames.TryGetValue(c.AuthorId, out var cn) ? cn : "Unknown";

                            <div class="comment-box @(c.Visibility == Visibility.Private ? "comment-box--private" : "")">
                                @if (c.IsSoftDeleted)
                                {
                                    <p class="comment-box__removed">Removed.</p>
                                }
                                else
                                {
                                    <div class="comment-box__meta">
                                        <strong>@commentName</strong>
                                        <span class="comment-box__date">@c.CreatedAt.ToString("dd MMM")</span>
                                        @if (c.Visibility == Visibility.Private)
                                        {
                                            <span class="comment-box__private">[Private]</span>
                                        }
                                    </div>

                                    <p class="comment-box__body">@c.Body</p>

                                    <form asp-action="AddComment" method="post" class="comment-box__reply-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="SectionId" value="@item.Scene.Id" />
                                        <input type="hidden" name="ParentCommentId" value="@c.Id" />
                                        <input type="text" name="Body" placeholder="Reply..." class="comment-box__reply-input" />
                                        <button type="submit" class="btn btn-xs">Reply</button>
                                    </form>
                                }
                            </div>

                            @if (replies.TryGetValue(c.Id, out var childReplies))
                            {
                                @foreach (var r in childReplies)
                                {
                                    var replyName = Model.CommentAuthorNames.TryGetValue(r.AuthorId, out var rn) ? rn : "Unknown";

                                    <div class="comment-box comment-box--reply @(r.Visibility == Visibility.Private ? "comment-box--private" : "")">
                                        @if (r.IsSoftDeleted)
                                        {
                                            <p class="comment-box__removed">Removed.</p>
                                        }
                                        else
                                        {
                                            <div class="comment-box__meta">
                                                <strong>@replyName</strong>
                                                <span class="comment-box__date">@r.CreatedAt.ToString("dd MMM")</span>
                                            </div>

                                            <p class="comment-box__body">@r.Body</p>

                                            <form asp-action="AddComment" method="post" class="comment-box__reply-form">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="SectionId" value="@item.Scene.Id" />
                                                <input type="hidden" name="ParentCommentId" value="@c.Id" />
                                                <input type="text" name="Body" placeholder="Reply..." class="comment-box__reply-input" />
                                                <button type="submit" class="btn btn-xs">Reply</button>
                                            </form>
                                        }
                                    </div>
                                }
                            }
                        }

                        <div class="add-comment-mini">
                            <form asp-action="AddComment" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="SectionId" value="@item.Scene.Id" />
                                <textarea name="Body" rows="3" placeholder="Comment on @item.Scene.Title..."></textarea>

                                <div class="add-comment-mini__actions">
                                    <label class="add-comment-mini__private">
                                        <input type="checkbox" name="IsPrivate" />
                                        Private
                                    </label>
                                    <button type="submit" class="btn btn-xs">Post</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            }

            <div class="chapter-comments" id="chapter-comments">
                <h3>Chapter Comments</h3>
                <p class="chapter-comments__intro">Use chapter comments for overall impressions of the chapter as a whole.</p>

                @{
                    var chapterRoots = Model.ChapterComments.Where(c => c.ParentCommentId == null).ToList();
                    var chapterReplies = Model.ChapterComments.Where(c => c.ParentCommentId != null)
                        .GroupBy(c => c.ParentCommentId!.Value)
                        .ToDictionary(g => g.Key, g => g.ToList());
                }

                @foreach (var c in chapterRoots)
                {
                    var commentName = Model.CommentAuthorNames.TryGetValue(c.AuthorId, out var cn) ? cn : "Unknown";

                    <div class="chapter-comment @(c.Visibility == Visibility.Private ? "chapter-comment--private" : "")">
                        @if (c.IsSoftDeleted)
                        {
                            <p class="chapter-comment__removed">This comment has been removed.</p>
                        }
                        else
                        {
                            <div class="chapter-comment__meta">
                                <strong>@commentName</strong>
                                <span class="chapter-comment__date">@c.CreatedAt.ToString("dd MMM yyyy")</span>
                                @if (c.Visibility == Visibility.Private)
                                {
                                    <span class="chapter-comment__private">[Private]</span>
                                }
                            </div>

                            <p class="chapter-comment__body">@c.Body</p>

                            <form asp-action="AddComment" method="post" class="chapter-comment__reply-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="SectionId" value="@Model.Chapter.Id" />
                                <input type="hidden" name="ParentCommentId" value="@c.Id" />
                                <input type="text" name="Body" placeholder="Reply..." class="chapter-comment__reply-input" />
                                <button type="submit" class="btn btn-sm">Reply</button>
                            </form>
                        }
                    </div>

                    @if (chapterReplies.TryGetValue(c.Id, out var childReplies))
                    {
                        @foreach (var r in childReplies)
                        {
                            var replyName = Model.CommentAuthorNames.TryGetValue(r.AuthorId, out var rn) ? rn : "Unknown";

                            <div class="chapter-comment chapter-comment--reply @(r.Visibility == Visibility.Private ? "chapter-comment--private" : "")">
                                @if (r.IsSoftDeleted)
                                {
                                    <p class="chapter-comment__removed">This comment has been removed.</p>
                                }
                                else
                                {
                                    <div class="chapter-comment__meta">
                                        <strong>@replyName</strong>
                                        <span class="chapter-comment__date">@r.CreatedAt.ToString("dd MMM yyyy")</span>
                                    </div>

                                    <p class="chapter-comment__body">@r.Body</p>

                                    <form asp-action="AddComment" method="post" class="chapter-comment__reply-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="SectionId" value="@Model.Chapter.Id" />
                                        <input type="hidden" name="ParentCommentId" value="@c.Id" />
                                        <input type="text" name="Body" placeholder="Reply..." class="chapter-comment__reply-input" />
                                        <button type="submit" class="btn btn-sm">Reply</button>
                                    </form>
                                }
                            </div>
                        }
                    }
                }

                <div class="chapter-comment-form">
                    <h4 class="chapter-comment-form__title">Add a chapter comment</h4>

                    <form asp-action="AddComment" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="SectionId" value="@Model.Chapter.Id" />

                        <textarea name="Body"
                                  rows="4"
                                  placeholder="Your overall thoughts on this chapter..."
                                  class="chapter-comment-form__textarea"></textarea>

                        <div class="chapter-comment-form__actions">
                            <label class="chapter-comment-form__private">
                                <input type="checkbox" name="IsPrivate" />
                                Private - only you and the author can see this
                            </label>

                            <button type="submit" class="btn">Post Comment</button>
                        </div>
                    </form>
                </div>
            </div>
        </main>
    </div>
</div>

<script>
    (function () {
        var key = 'scroll_chapter_@Model.Chapter.Id';
        var saved = localStorage.getItem(key);
        if (saved) {
            setTimeout(function () { window.scrollTo(0, parseInt(saved, 10)); }, 100);
        }

        var links = document.querySelectorAll('.chapter-sidebar .chapter-sidebar__link[href^="#"]');
        var sections = [];
        links.forEach(function (link) {
            var id = link.getAttribute('href').substring(1);
            var el = document.getElementById(id);
            if (el) {
                sections.push({ el: el, link: link });
            }
        });

        function updateActive() {
            var scrollY = window.scrollY + 120;
            var current = null;
            sections.forEach(function (s) {
                if (s.el.offsetTop <= scrollY) current = s;
            });

            links.forEach(function (l) {
                l.classList.remove('chapter-sidebar__link--active');
            });

            if (current) {
                current.link.classList.add('chapter-sidebar__link--active');
            }
        }

        var timer;
        window.addEventListener('scroll', function () {
            clearTimeout(timer);
            timer = setTimeout(function () {
                localStorage.setItem(key, window.scrollY);
                updateActive();
            }, 150);
        });

        updateActive();
    })();

    (function () {
        var toggle = document.getElementById('readerContentsToggle');
        var panel = document.getElementById('readerContentsPanel');

        if (!toggle || !panel) {
            return;
        }

        toggle.addEventListener('click', function () {
            var isOpen = panel.classList.toggle('is-open');
            toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        });

        panel.querySelectorAll('a[href^="#"]').forEach(function (link) {
            link.addEventListener('click', function () {
                panel.classList.remove('is-open');
                toggle.setAttribute('aria-expanded', 'false');
            });
        });
    })();
</script>